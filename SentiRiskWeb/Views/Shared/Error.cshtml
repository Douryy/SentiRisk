@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<hr />

<h3>🔌 Connexion API</h3>
<p><strong>Statut :</strong> @ViewBag.ApiStatus</p>

<hr />

<h3>📌 Résumé (fictif pour l’instant)</h3>
<p>Portefeuille : <strong>@ViewBag.PortfolioName</strong></p>
<p>Nombre d’actifs : <strong>@ViewBag.AssetCount</strong></p>

<p>Stress Global : <strong>@ViewBag.GlobalStressScore</strong></p>
<p>VaR Sentimentale : <strong>@ViewBag.VaRSentiment %</strong></p>

<hr />

<h3>🌡️ Heatmap sectorielle (fictif)</h3>
<table border="1" cellpadding="6">
    <tr>
        <th>Secteur</th>
        <th>Impact</th>
    </tr>

    @foreach (var sector in (Dictionary<string, double>)ViewBag.SectorHeatmap)
    {
        <tr>
            <td>@sector.Key</td>
            <td>@sector.Value</td>
        </tr>
    }
</table>

<hr />

<h3>🧾 JSON brut depuis l’API : /api/portfolios</h3>
<pre style="background:#f4f4f4; padding:10px; border-radius:6px; overflow:auto;">
@ViewBag.PortfoliosJson
</pre>
