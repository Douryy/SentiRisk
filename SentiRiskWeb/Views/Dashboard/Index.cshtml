@model SentiRiskWeb.ViewModels.DashboardViewModel
@using System.Globalization

@functions {
    // Renvoie une classe CSS selon l'intensité (0..100)
    public string LevelClass(decimal value)
    {
        if (value >= 25) return "lvl-high";
        if (value >= 10) return "lvl-mid";
        return "lvl-low";
    }
    public string StressClass(decimal impact)
{
    if (impact >= 20) return "lvl-high";
    if (impact >= 10) return "lvl-mid";
    return "lvl-low";
}

    // Convert decimal -> string invariant
    public string D(decimal d) => d.ToString("0.##", CultureInfo.InvariantCulture);
}

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    :root {
        --bg: #0b1220;
        --card: #111a2e;
        --card2: #0f172a;
        --text: #e6edf7;
        --muted: #9aa7bd;
        --line: #23314d;
        --green: #22c55e;
        --amber: #f59e0b;
        --red: #ef4444;
        --blue: #60a5fa;
        --violet: #a78bfa;
    }

    body {
        background: linear-gradient(180deg, #070b15 0%, #0b1220 55%, #070b15 100%);
        color: var(--text);
    }

    h1, h2, h3 {
        margin: 0 0 10px 0;
    }

    .container {
        max-width: 1150px;
        margin: 0 auto;
        padding: 22px 16px;
    }

    .topbar {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .subtitle {
        color: var(--muted);
        font-size: 0.95rem;
        margin-top: 6px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
        margin: 16px 0 22px;
    }

    .card {
        background: radial-gradient(1200px 400px at 20% 0%, rgba(96,165,250,0.12), transparent 60%), radial-gradient(900px 420px at 90% 20%, rgba(167,139,250,0.10), transparent 55%), var(--card);
        border: 1px solid rgba(35,49,77,.7);
        border-radius: 16px;
        padding: 14px 14px;
        box-shadow: 0 10px 35px rgba(0,0,0,.35);
    }

        .card h3 {
            font-size: 1.02rem;
            letter-spacing: .2px;
        }

    .muted {
        color: var(--muted);
    }

    .kpi {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 10px;
    }

        .kpi .value {
            font-size: 1.6rem;
            font-weight: 700;
        }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: .82rem;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.10);
        background: rgba(255,255,255,.06);
        color: var(--text);
        white-space: nowrap;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--blue);
        box-shadow: 0 0 0 4px rgba(96,165,250,.12);
    }

    .span-4 {
        grid-column: span 4;
    }

    .span-6 {
        grid-column: span 6;
    }

    .span-8 {
        grid-column: span 8;
    }

    .span-12 {
        grid-column: span 12;
    }

    .section-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 18px 0 10px;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.10);
        color: var(--muted);
        font-size: .82rem;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 14px;
        border: 1px solid rgba(35,49,77,.7);
        background: rgba(15,23,42,.55);
    }

        .table th, .table td {
            padding: 10px 10px;
            border-bottom: 1px solid rgba(35,49,77,.55);
            font-size: .95rem;
        }

        .table th {
            text-align: left;
            color: #cbd5e1;
            font-weight: 600;
        }

        .table tr:hover td {
            background: rgba(96,165,250,.05);
        }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.10);
        font-size: .85rem;
    }

        .pill .mini {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

    .lvl-low {
        color: #b7f7cf;
    }

    .lvl-mid {
        color: #ffe2a8;
    }

    .lvl-high {
        color: #ffb4b4;
    }

    .mini.lvl-low {
        background: var(--green);
        box-shadow: 0 0 0 4px rgba(34,197,94,.10);
    }

    .mini.lvl-mid {
        background: var(--amber);
        box-shadow: 0 0 0 4px rgba(245,158,11,.10);
    }

    .mini.lvl-high {
        background: var(--red);
        box-shadow: 0 0 0 4px rgba(239,68,68,.10);
    }

    .bar {
        height: 10px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 999px;
        overflow: hidden;
        width: 140px;
    }

        .bar > span {
            display: block;
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, rgba(34,197,94,0.95), rgba(245,158,11,0.95), rgba(239,68,68,0.95));
        }

    .heat {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-top: 10px;
    }

    .heat-item {
        background: rgba(15,23,42,.55);
        border: 1px solid rgba(35,49,77,.6);
        border-radius: 14px;
        padding: 10px 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .heat-left {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .heat-name {
        font-weight: 600;
    }

    .heat-sub {
        color: var(--muted);
        font-size: .85rem;
    }

    .heat-score {
        font-weight: 800;
        font-size: 1.05rem;
        padding: 6px 10px;
        border-radius: 12px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.10);
    }

    .score-green {
        color: var(--green);
    }

    .score-amber {
        color: var(--amber);
    }

    .score-red {
        color: var(--red);
    }

    @@media (max-width: 980px) {
        .span-4, .span-6, .span-8 {
            grid-column: span 12;
        }

        .heat {
            grid-template-columns: 1fr;
        }

        .bar {
            width: 110px;
        }
    }
</style>

<div class="container">

    <div class="topbar">
        <div>
            <h1>Sentiment-Driven Risk Analyzer</h1>
            <div class="subtitle">Dashboard • Portefeuilles et exposition sectorielle (données API)</div>
        </div>
        <div class="badge">
            <span class="dot"></span>
            Données en direct via API
        </div>
    </div>

    @if (Model.Portfolios == null || Model.Portfolios.Count == 0)
    {
        <div class="card">
            <h3>Aucun portefeuille trouvé</h3>
            <p class="muted">Ajoute un portefeuille et des actifs via ton API, puis recharge la page.</p>
        </div>
    }
    else
    {
        foreach (var p in Model.Portfolios)
        {
            var totalWeight = p.Assets?.Sum(a => a.Weight) ?? 0m;
            var assetCount = p.Assets?.Count ?? 0;

            // Heatmap: exposition par secteur (somme des poids)
            var sectorMap = (p.Assets ?? new()).GroupBy(a => a.Sector ?? "N/A")
            .ToDictionary(g => g.Key, g => g.Sum(x => x.Weight));

            // top 6 secteurs
            var topSectors = sectorMap.OrderByDescending(x => x.Value).Take(6).ToList();

            <div class="section-title">
                <div>
                    <h2>@p.Name</h2>
                    <div class="subtitle">@p.Description</div>
                </div>
                <span class="chip">Poids total: @D(totalWeight * 100)% • Actifs: @assetCount</span
            </div>

            <div class="grid">
                <div class="card span-4">
                    <h3>Résumé</h3>
                    <div class="kpi">
                        <div>
                            <div class="muted">Nombre d’actifs</div>
                            <div class="value">@assetCount</div>
                        </div>
                        <span class="badge"><span class="dot" style="background:var(--violet); box-shadow:0 0 0 4px rgba(167,139,250,.12)"></span>Portefeuille</span>
                    </div>
                    <div class="muted" style="margin-top:10px;">
                      Total poids déclaré: <strong>@D(totalWeight * 100)%</strong>
                        @if (totalWeight != 1m)
                        {
                            <span class="pill" style="margin-left:8px;">
                                <span class="mini lvl-mid"></span>
                                Attention: ≠ 100%
                            </span>
                        }
                    </div>
                    <div class="muted" style="margin-top:6px;">
                        Exposition totale:
                        <strong style="color:var(--blue)">
                            $@D(p.Assets?.Sum(a => a.Exposition) ?? 0)
                        </strong>
                    </div>
                </div>

                <div class="card span-8">
                    <h3>Heatmap sectorielle (exposition)</h3>
                    <div class="muted">Plus un secteur est “rouge”, plus son poids dans le portefeuille est élevé.</div>

                    <div class="heat">
                        @foreach (var s in topSectors)
                        {
                            // Couleur selon poids secteur
                            var cls = s.Value >= 25 ? "score-red" : (s.Value >= 10 ? "score-amber" : "score-green");
                            <div class="heat-item">
                                <div class="heat-left">
                                    <div class="heat-name">@s.Key</div>
                                    <div class="heat-sub">Poids agrégé</div>
                                </div>
                                <div class="heat-score @cls">@D(s.Value)%</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card span-12">
                    <h3>Détails des actifs</h3>
                    <div class="muted">Badges & barres colorés selon le poids (sensibilité potentielle).</div>

                    <div style="margin-top:12px;">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Actif</th>
                                    <th>Ticker</th>
                                    <th>Secteur</th>
                                    <th>Poids</th>
                                    <th>Visual</th>
                                    <th>Prix</th>
                                    <th>Stress (%)</th>
                                    <th>Exposition ($)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in (p.Assets ?? new()))
                                {
                                    var lvl = LevelClass(a.Weight);
                                    var stressCls = StressClass(a.StressImpact);
                                    var barWidth = (a.Weight > 100 ? 100 : (a.Weight < 0 ? 0 : a.Weight));
                                    <tr>
                                        <td>@a.Name</td>
                                        <td><span class="pill"><span class="mini @lvl"></span>@a.Ticker</span></td>
                                        <td><span class="chip">@a.Sector</span></td>
                                        <td class="@lvl"><strong>@D(a.Weight * 100)%</strong></td>
                                        <td>
                                            <div class="bar" title="@D(a.Weight)%">
                                                <span style="width:@D(barWidth)%;"></span>
                                            </div>
                                        </td>
                                        <td>@a.CurrentPrice</td>
                                        <td class="@stressCls">
                                         <strong>@D(a.StressImpact)%</strong>
                                         </td>
                                        <td><strong style="color:var(--blue)">@D(a.Exposition)</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="muted" style="margin-top:10px;">
                        Astuce : quand tu ajouteras le stress-test, tu pourras colorer selon l’<strong>impact</strong> plutôt que le poids.
                    </div>
                </div>
            </div>
        }
    }
</div>
